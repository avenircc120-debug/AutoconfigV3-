{
  "name": "autoconfig-ultimate",
  "version": "3.1.0",
  "description": "AutoConfig Ultimate — 18 modules fusionnés : Gateway · ZeroClone · Fortress · FedaPay · OAuth · Supabase · Vercel · StackDetector · MasterOrchestrator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:int": "jest tests/integration --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8",
    "@google/generative-ai": "^0.15.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.4",
    "@jest/globals": "^29.7.0",
    "jest-mock-axios": "^4.7.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "core/**/*.js",
      "services/**/*.js",
      "utils/**/*.js",
      "routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    },
    "testPathPattern": "tests/",
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}