# ╔═══════════════════════════════════════════════════════════════════════╗
# ║     AUTOCONFIG ULTIMATE v3.1 — Guide des Variables d'Environnement   ║
# ║                                                                       ║
# ║  📋 USAGE :                                                           ║
# ║     Local    → Copier en .env et remplir les valeurs                  ║
# ║     Vercel   → Settings → Environment Variables → ajouter chaque clé ║
# ║     Replit   → Onglet "Secrets" → ajouter chaque clé                 ║
# ║                                                                       ║
# ║  🔐 SÉCURITÉ :                                                        ║
# ║     • Ne jamais committer le fichier .env                             ║
# ║     • .gitignore protège déjà .env                                    ║
# ║     • Aucune clé n'est codée en dur dans le code                      ║
# ╚═══════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [1] SERVEUR  (obligatoire)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=production
PORT=3000

# URL publique du serveur (utilisée pour les redirections OAuth)
# → Sur Vercel : https://ton-projet.vercel.app
# → En local   : http://localhost:3000
BASE_URL=https://ton-projet.vercel.app

# Origines autorisées pour CORS (interface mobile → backend)
# → '*' = tout le monde  |  'https://ton-app.com' = domaine spécifique
ALLOWED_ORIGIN=*

LOG_LEVEL=info

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [2] SÉCURITÉ AES-256-GCM  🔴 CRITIQUE — le serveur refuse de démarrer sans cette clé
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Clé maître pour chiffrer tous les tokens utilisateurs en mémoire.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Exemple de valeur (NE PAS utiliser celle-ci) :
MASTER_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [3] GITHUB
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Token personnel (Zero-Clone — lecture/écriture de fichiers sans git clone)
# Créer sur : https://github.com/settings/tokens → Generate new token (classic)
# Scopes requis : repo ✓  workflow ✓  read:user ✓
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth App (bouton "Login with GitHub")
# Créer sur : https://github.com/settings/developers → New OAuth App
#   Homepage URL   : https://ton-projet.vercel.app
#   Callback URL   : https://ton-projet.vercel.app/api/oauth/github/callback
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [4] GOOGLE OAUTH (bouton "Login with Google")
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Créer sur : https://console.cloud.google.com
#   → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   → Type : Web Application
#   Redirect URI autorisé : https://ton-projet.vercel.app/api/oauth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [5] SUPABASE — Auto-provisioning de bases de données
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Token de gestion (crée des projets Supabase automatiquement)
# Obtenir sur : https://app.supabase.com/account/tokens → Generate new token
SUPABASE_MANAGEMENT_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Région par défaut pour les nouveaux projets Supabase
# Valeurs : eu-west-1 (Paris) | us-east-1 | ap-southeast-1 | af-south-1
DEFAULT_SUPABASE_REGION=eu-west-1

# ↓↓↓ Ces 5 variables sont AUTO-PROVISIONNÉES par l'orchestrateur.
#     Ne pas remplir manuellement — elles seront injectées automatiquement.
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [6] VERCEL — Auto-provisioning de déploiements
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Token API Vercel (crée et déploie des projets automatiquement)
# Obtenir sur : https://vercel.com/account/tokens → Create Token
VERCEL_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Team ID (optionnel — uniquement pour les comptes Vercel Team/Pro)
# Laisser vide pour un compte personnel
VERCEL_TEAM_ID=

# Framework forcé (laisser vide = auto-détection par identifyStack())
# Valeurs : nextjs | nuxtjs | remix | svelte | astro | vite | gatsby
FORCE_VERCEL_FRAMEWORK=

# ↓↓↓ Auto-provisionnées — ne pas remplir manuellement
VERCEL_PROJECT_ID=
VERCEL_DEPLOY_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [7] GEMINI AI — Free Tier optimisé (15 RPM, cache, rotation de clés)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Rotation de clés : tableau JSON (recommandé pour Free Tier)
# Obtenir sur : https://aistudio.google.com/app/apikey
# Format JSON  : ["AIzaSy_key1","AIzaSy_key2","AIzaSy_key3"]
# Format CSV   : AIzaSy_key1,AIzaSy_key2
GEMINI_KEYS=["AIzaSy_REMPLACER_PAR_VOTRE_CLE_GEMINI"]

# Clé unique (alternative plus simple si une seule clé)
# GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle à utiliser (gemini-1.5-flash = gratuit et rapide)
GEMINI_MODEL=gemini-1.5-flash

# Durée du cache des analyses en secondes (86400 = 24 heures)
GEMINI_CACHE_TTL_SECONDS=86400

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [8] FEDAPAY — Paiement Mobile Money (Bénin)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Obtenir sur : https://app.fedapay.com/settings/api
# Sandbox (tests) : préfixe sk_sandbox_
# Live (production) : préfixe sk_live_
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret pour vérifier les signatures des webhooks FedaPay
FEDAPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Environnement FedaPay : sandbox (tests) | live (production)
FEDAPAY_ENV=sandbox

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  RÉCAPITULATIF — Variables à ajouter dans Vercel Dashboard
#  Settings → Environment Variables → Add New
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
#  🔴 OBLIGATOIRES (le serveur refuse de démarrer sans elles) :
#     MASTER_SECRET
#
#  🟡 RECOMMANDÉES (désactivent des modules si absentes) :
#     GITHUB_TOKEN
#     GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET
#     GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET
#     SUPABASE_MANAGEMENT_TOKEN
#     VERCEL_API_TOKEN
#
#  🔵 OPTIONNELLES (fonctionnalités avancées) :
#     GEMINI_KEYS (ou GEMINI_API_KEY)
#     FEDAPAY_SECRET_KEY + FEDAPAY_WEBHOOK_SECRET
#     VERCEL_TEAM_ID
#
#  ⚙️  CONFIGURATION (valeurs par défaut si absentes) :
#     NODE_ENV=production
#     PORT=3000
#     BASE_URL=https://ton-projet.vercel.app
#     ALLOWED_ORIGIN=*
#     DEFAULT_SUPABASE_REGION=eu-west-1
#     GEMINI_MODEL=gemini-1.5-flash
#     FEDAPAY_ENV=sandbox

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  [9] LLM ROUTER MULTI-PROVIDER — 70+ RPM gratuit total
#  Inscription gratuite pour chaque provider :
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
#  Provider     RPM   Inscription
#  ─────────────────────────────────────────────────────────────────────
#  Gemini        15   https://aistudio.google.com/app/apikey
#  Groq          30   https://console.groq.com → API Keys
#  Mistral        5   https://console.mistral.ai → API Keys
#  Cohere        20   https://dashboard.cohere.com/api-keys
#  HuggingFace   ∞    https://huggingface.co/settings/tokens
#  ─────────────────────────────────────────────────────────────────────
#  TOTAL théorique : 70+ RPM avec rotation automatique
#
#  ↓ Ajouter autant de clés que tu veux. Le routeur bascule automatiquement.

# Groq (Llama 3.1 ultra-rapide — 30 RPM gratuit)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modèle Groq (défaut: llama-3.1-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant   # Plus rapide, moins précis

# Mistral AI (5 RPM gratuit)
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MISTRAL_MODEL=mistral-small-latest

# Cohere (20 RPM gratuit avec Trial key)
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# COHERE_MODEL=command-r

# HuggingFace (illimité mais lent — backup ultime)
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HF_MODEL=HuggingFaceH4/zephyr-7b-beta
