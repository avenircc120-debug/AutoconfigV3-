# ╔══════════════════════════════════════════════════════════════════╗
# ║  AutoConfig Ultimate — .gitignore complet pour Node.js          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── SECRETS & ENVIRONNEMENT ──────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.pem
*.key
*.p12
*.pfx

# ── DÉPENDANCES ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/

# ── LOGS ─────────────────────────────────────────────────────────────
logs/
*.log
*.log.*
lerna-debug.log*

# ── BUILD / DIST ─────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/
.vercel/
.cache/
.turbo/

# ── TESTS & COUVERTURE ───────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
.jest-cache/

# ── OS ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── ÉDITEURS ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── RUNTIME ──────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock
.node_repl_history

# ── REPLIT ───────────────────────────────────────────────────────────
.replit
replit.nix
.upm/
.breakpoints

# ── DOCKER ───────────────────────────────────────────────────────────
# (garder Dockerfile et docker-compose.yml en dépôt)
.docker/

# ── DIVERS ───────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.terraform/
.serverless/
# Cache Gemini (généré automatiquement — ne pas committer)
.cache/
